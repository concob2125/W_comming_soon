{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/CommingSoon",
      "destination": "/CommingSoon/index.html"
    },
    {
      "source": "/ComingSoon",
      "destination": "/CommingSoon/index.html"
    },
    {
      "source": "/Geometrydashiver",
      "destination": "/Geometrydashiver/index.html"
    },
    {
      "source": "/Geometridashiver",
      "destination": "/Geometrydashiver/index.html"
    }
  ]
}
